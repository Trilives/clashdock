              "hk-01",
              "DIRECT"
            ]
          }
        ],
        "rules": [
          "GEOIP,CN,DIRECT",
          "MATCH,Proxies"
        ],
        "external-ui": "/golden-root/state/ui",
        "log-level": "warning",
        "profile": {
          "store-selected": true
